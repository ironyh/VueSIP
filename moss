#!/usr/bin/env python3
"""
OpenMOSS Task CLI wrapper for VueSIP Reviewer
Usage: ./moss <command> [args]

Uses the local OpenMOSS instance at http://127.0.0.1:6567
"""
import sys
import subprocess
import tempfile
import os

# VueSIP OpenMOSS instance
BASE_URL = "http://127.0.0.1:6567"
API_KEY = "ak_825ab2dc5d34796d4fc635e709f4711e"
OPENMOSS_CLI = "/home/irony/.openmoss/instances/vuesip/task-cli.py"


def main():
    if len(sys.argv) < 2:
        print("Usage: moss <command> [args]", file=sys.stderr)
        print("       moss rules", file=sys.stderr)
        print("       moss score logs", file=sys.stderr)
        print("       moss st list --status review", file=sys.stderr)
        sys.exit(1)

    # Check CLI exists
    if not os.path.exists(OPENMOSS_CLI):
        print(f"Error: OpenMOSS CLI not found at {OPENMOSS_CLI}", file=sys.stderr)
        sys.exit(1)

    # Execute with API key
    args = ['python3', OPENMOSS_CLI, '--key', API_KEY] + sys.argv[1:]
    result = subprocess.run(args, capture_output=True, text=True, timeout=120)
    print(result.stdout, end='')
    if result.stderr:
        print(result.stderr, end='', file=sys.stderr)
    sys.exit(result.returncode)


if __name__ == "__main__":
    main()
