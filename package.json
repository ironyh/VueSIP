{
  "name": "vuesip",
  "version": "1.2.1",
  "description": "A headless Vue.js component library for SIP/VoIP applications",
  "type": "module",
  "author": "Arash Molavi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ironyh/VueSIP.git"
  },
  "bugs": {
    "url": "https://github.com/ironyh/VueSIP/issues"
  },
  "homepage": "https://github.com/ironyh/VueSIP#readme",
  "keywords": [
    "vue",
    "sip",
    "voip",
    "webrtc",
    "headless",
    "composables",
    "jssip",
    "telephony",
    "asterisk",
    "dialpad"
  ],
  "main": "./dist/vuesip.cjs",
  "module": "./dist/vuesip.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vuesip.js",
      "require": "./dist/vuesip.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --project tsconfig.build.json",
    "build:playground": "vite build --config vite.config.playground.ts",
    "build:templates": "pnpm run build:template:minimal && pnpm run build:template:softphone && pnpm run build:template:callcenter",
    "build:template:minimal": "cd templates/minimal && pnpm run build",
    "build:template:softphone": "cd templates/basic-softphone && pnpm run build",
    "build:template:callcenter": "cd templates/call-center && pnpm run build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:performance": "vitest run tests/performance",
    "test:performance:bench": "vitest bench tests/performance/benchmarks",
    "test:performance:bench:json": "vitest bench tests/performance/benchmarks --outputJson tests/performance/.benchmark-results.json",
    "test:performance:bench:compare": "vitest bench tests/performance/benchmarks --compare tests/performance/.benchmark-baseline.json",
    "test:performance:bench:update-baseline": "vitest bench tests/performance/benchmarks --outputJson tests/performance/.benchmark-baseline.json",
    "test:performance:load": "vitest run tests/performance/load-tests",
    "test:performance:metrics": "vitest run tests/performance/metrics",
    "test:performance:metrics:full": "pnpm run build && pnpm run test:performance:metrics",
    "test:performance:gc": "node --expose-gc ./node_modules/vitest/vitest.mjs tests/performance",
    "test:performance:all": "pnpm run build && pnpm run test:performance:gc",
    "test:watch": "vitest watch",
    "test:unit:watch": "vitest watch tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:report": "playwright show-report",
    "test:e2e:smoke": "playwright test app-functionality.spec.ts --grep '@smoke' --project=chromium --workers=2",
    "test:e2e:fast": "playwright test --project=chromium --workers=2 --timeout=5000",
    "test:e2e:slow": "playwright test multi-user.spec.ts network-conditions.spec.ts performance.spec.ts --project=chromium --workers=1",
    "test:e2e:ci": "playwright test --project=chromium --workers=4",
    "test:e2e:a11y": "playwright test accessibility.spec.ts --project=chromium --workers=2",
    "test:e2e:visual": "playwright test visual-regression.spec.ts --project=chromium --workers=1",
    "test:e2e:visual:update": "playwright test visual-regression.spec.ts --update-snapshots --project=chromium",
    "test:e2e:auth": "playwright test basic-call-flow.spec.ts --grep 'connect|registration|configuration' --project=chromium --workers=2",
    "test:e2e:config": "playwright test app-functionality.spec.ts --grep 'Configuration|settings' --project=chromium --workers=2",
    "test:e2e:outbound": "playwright test basic-call-flow.spec.ts --grep 'outgoing call|make.*call' --project=chromium --workers=2",
    "test:e2e:inbound": "playwright test incoming-call.spec.ts --project=chromium --workers=2",
    "test:e2e:dtmf": "playwright test basic-call-flow.spec.ts app-functionality.spec.ts --grep 'DTMF|dtmf' --project=chromium --workers=2",
    "test:e2e:transfer": "playwright test basic-call-flow.spec.ts --grep 'transfer' --project=chromium --workers=2",
    "test:e2e:hold": "playwright test basic-call-flow.spec.ts --grep 'hold' --project=chromium --workers=2",
    "test:e2e:media": "playwright test av-quality.spec.ts app-functionality.spec.ts --grep 'Device|media|audio|video' --project=chromium --workers=2",
    "test:e2e:audio": "playwright test av-quality.spec.ts app-functionality.spec.ts --grep 'audio|microphone|speaker' --project=chromium --workers=2",
    "test:e2e:video": "playwright test av-quality.spec.ts --grep 'video|camera' --project=chromium --workers=2",
    "test:e2e:history": "playwright test app-functionality.spec.ts basic-call-flow.spec.ts --grep 'history' --project=chromium --workers=2",
    "test:e2e:onboarding": "playwright test app-functionality.spec.ts --grep 'Initialization|initial' --project=chromium --workers=2",
    "test:e2e:daily": "playwright test basic-call-flow.spec.ts incoming-call.spec.ts --project=chromium --workers=2",
    "test:e2e:troubleshoot": "playwright test error-scenarios.spec.ts --project=chromium --workers=2",
    "test:e2e:network": "playwright test network-conditions.spec.ts --project=chromium --workers=1",
    "test:e2e:errors": "playwright test error-scenarios.spec.ts --project=chromium --workers=2",
    "test:e2e:performance": "playwright test performance.spec.ts --project=chromium --workers=1",
    "test:e2e:integration": "playwright test multi-user.spec.ts --project=chromium --workers=1",
    "test:e2e:calling": "playwright test basic-call-flow.spec.ts incoming-call.spec.ts --project=chromium --workers=2",
    "test:e2e:quality": "playwright test accessibility.spec.ts visual-regression.spec.ts performance.spec.ts --project=chromium --workers=1",
    "test:e2e:resilience": "playwright test error-scenarios.spec.ts network-conditions.spec.ts --project=chromium --workers=1",
    "test:e2e:core": "playwright test app-functionality.spec.ts basic-call-flow.spec.ts --project=chromium --workers=2",
    "test:e2e:full": "playwright test --project=chromium --workers=2",
    "test:e2e:multiuser": "playwright test multi-user.spec.ts --project=chromium --workers=1",
    "test:e2e:advanced": "playwright test accessibility.spec.ts network-conditions.spec.ts performance.spec.ts multi-user.spec.ts --project=chromium --workers=1",
    "coverage": "vitest run --coverage",
    "coverage:unit": "vitest run --coverage tests/unit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-staged": "lint-staged",
    "format": "prettier --write \"src/**/*.{ts,vue,json}\"",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:api": "typedoc && node scripts/fix-typedoc-vue-blocks.js",
    "docs:api:watch": "typedoc --watch",
    "docs:all": "pnpm run docs:api && pnpm run docs:build",
    "check:exports": "node scripts/check-exports.mjs",
    "typecheck": "tsc --noEmit",
    "smoke:template:minimal": "node scripts/smoke-template-build.mjs templates/minimal",
    "type-check": "vue-tsc --noEmit",
    "prepare": "husky"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@jridgewell/source-map": "^0.3.11",
    "jssip": "^3.13.6",
    "pinia": "2.3.1",
    "webrtc-adapter": "^9.0.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-istanbul": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lighthouse": "^13.0.3",
    "lint-staged": "^16.4.0",
    "playwright-lighthouse": "^4.0.0",
    "prettier": "^3.8.1",
    "primeicons": "^7.0.0",
    "primevue": "^3.53.1",
    "puppeteer-core": "^24.40.0",
    "terser": "^5.46.1",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-plugin-missing-exports": "^4.1.3",
    "typescript": "~5.4.5",
    "vite": "^7.3.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.2",
    "vue": "^3.5.32",
    "vue-tsc": "^2.2.12",
    "wrangler": "^4.80.0"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.14.2",
  "pnpm": {
    "overrides": {
      "markdown-it@<12.3.2": ">=12.3.2",
      "nth-check@<2.0.1": ">=2.0.1",
      "vite@<2.9.16": ">=2.9.16",
      "vite@<3.2.11": ">=3.2.11",
      "vite@<=3.2.10": ">=3.2.11",
      "vite@<2.9.13": ">=2.9.13",
      "esbuild@<=0.24.2": ">=0.25.0",
      "vite@<=4.5.5": ">=4.5.6",
      "vite@<4.5.10": ">=4.5.10",
      "vite@<4.5.13": ">=4.5.13",
      "vite@<=4.5.13": ">=4.5.14",
      "vite@<4.5.12": ">=4.5.12",
      "vite@<=5.4.19": ">=5.4.20",
      "postcss@<8.4.31": ">=8.4.31",
      "vite@<4.5.11": ">=4.5.11",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "undici@<7.24.0": ">=7.24.0",
      "yauzl@<3.2.1": ">=3.2.1",
      "flatted@<3.4.2": ">=3.4.2",
      "picomatch@<4.0.4": ">=4.0.4",
      "@types/node": "^22"
    }
  }
}
