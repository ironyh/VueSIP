# Real-PBX integration test credentials
#
# Copy this file to .env.test.local (git-ignored) and fill in real values.
# Vitest doesn't auto-load dotenv for node-env tests, so load with:
#   set -a && source .env.test.local && set +a && pnpm test:integration:real-pbx

# --- AMI (raw TCP 5038) ---
VUESIP_TEST_AMI_HOST=192.168.65.129
VUESIP_TEST_AMI_PORT=5038
VUESIP_TEST_AMI_USER=
VUESIP_TEST_AMI_SECRET=

# --- SIP over WebSocket ---
# Use ws:// from within the LAN; wss:// once TLS is enabled on the PBX.
VUESIP_TEST_WS_URL=ws://192.168.65.129:8088/ws
VUESIP_TEST_SIP_DOMAIN=pbx.telenurse.se
VUESIP_TEST_SIP_USER=102
VUESIP_TEST_SIP_PASSWORD=
VUESIP_TEST_SIP_DISPLAY_NAME=VueSIP Tests
